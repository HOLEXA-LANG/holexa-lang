{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HOLEXA",
  "scopeName": "source.holexa",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#functions" },
    { "include": "#types" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.holexa", "match": "//.*$" },
        { "name": "comment.block.holexa", "begin": "/\\*", "end": "\\*/" }
      ]
    },
    "keywords": {
      "patterns": [{
        "name": "keyword.control.holexa",
        "match": "\\b(let|mut|fn|return|if|else|while|for|in|loop|break|continue|struct|impl|trait|import|use|pub|match|enum|async|await|spawn|const|static|true|false|none|self|new)\\b"
      }]
    },
    "strings": {
      "name": "string.quoted.double.holexa",
      "begin": "\"", "end": "\"",
      "patterns": [{ "name": "constant.character.escape.holexa", "match": "\\\\." }]
    },
    "numbers": {
      "name": "constant.numeric.holexa",
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
    },
    "functions": {
      "name": "entity.name.function.holexa",
      "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()"
    },
    "types": {
      "name": "storage.type.holexa",
      "match": "\\b(int|float|String|bool|void|byte|char|i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|Array|Map)\\b"
    }
  }
}
